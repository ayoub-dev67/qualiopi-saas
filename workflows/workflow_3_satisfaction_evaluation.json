    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst FORM_SATISFACTION = '1vjF6Dxw0QgPbJHA_7HBMFnJApcHmLWK9amGm-S5FHfQ';\nconst FORM_EVALUATION = '1DM9QfOGbClRhxEw8jT6rPIz5mk7_cO_AvxN3OyYjLLg';\n\nfor (const item of items) {\n  const inscription_id = item.json.inscription_id;\n  const session_id = item.json.session_id;\n\n  item.json.url_satisfaction = `https://docs.google.com/forms/d/${FORM_SATISFACTION}/viewform?usp=pp_url&entry.inscription_id=${encodeURIComponent(inscription_id)}&entry.session_id=${encodeURIComponent(session_id)}`;\n  item.json.url_evaluation = `https://docs.google.com/forms/d/${FORM_EVALUATION}/viewform?usp=pp_url&entry.inscription_id=${encodeURIComponent(inscription_id)}&entry.session_id=${encodeURIComponent(session_id)}`;\n}\n\nreturn items;"
      },
      "id": "b1a0f7e1-0007-4a00-b000-000000000007",
