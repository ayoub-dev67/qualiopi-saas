        "subject": "=Évaluation et satisfaction — {{ $('Lire Formation').first().json.intitule }}",
        "emailType": "html",
        "message": "=<p>Bonjour {{ $json.prenom }} {{ $json.nom }},</p>\n<p>Suite à votre formation <strong>{{ $('Lire Formation').first().json.intitule }}</strong>, nous vous invitons à compléter les questionnaires suivants :</p>\n<ul>\n  <li><a href=\"{{ $json.url_satisfaction }}\">Questionnaire de satisfaction</a></li>\n  <li><a href=\"{{ $json.url_evaluation }}\">Questionnaire d'évaluation des acquis</a></li>\n</ul>\n<p>Merci de votre participation.</p>\n<p>Cordialement,<br>L'équipe formation</p>",
        "options": {}
      },
