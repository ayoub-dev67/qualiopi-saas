    {
      "parameters": {
        "jsCode": "// ============================================================\n// Préparer le HTML de la feuille d'émargement PDF\n// ============================================================\n// Lit le template templates/template_emargement.html depuis le\n// filesystem n8n et remplace les placeholders {{variable}}.\n// Construit dynamiquement les lignes {{rows_emargement}}.\n// Le fichier HTML n'est PAS embarqué dans ce workflow.\n// ============================================================\n\nconst fs = require('fs');\nconst templatePath = '/data/templates/template_emargement.html';\nlet html = fs.readFileSync(templatePath, 'utf8');\n\nconst session = $('Filtrer').item.json;\nconst formation = $('Lire Formation').item.json;\nconst emargements = $input.all().map(item => item.json);\n\n// Construire les lignes du tableau d'émargement\nconst rowsHtml = emargements.map(e => {\n  const statut = e.present === 'TRUE' || e.present === true\n    ? '<span style=\"color:#38a169;font-weight:bold;\">Présent</span>'\n    : '<span style=\"color:#e53e3e;font-weight:bold;\">Absent</span>';\n  return `<tr>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.nom || ''}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.prenom || ''}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.date || ''}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.heure_arrivee || ''}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.heure_depart || ''}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;text-align:center;\">${statut}</td>\n    <td style=\"padding:8px 12px;border:1px solid #e2e8f0;\">${e.signature || ''}</td>\n  </tr>`;\n}).join('');\n\nconst replacements = {\n  'formation_intitule': formation.intitule || '',\n  'session_id': session.session_id || '',\n  'date_debut': session.date_debut || '',\n  'date_fin': session.date_fin || '',\n  'lieu': session.lieu || '',\n  'rows_emargement': rowsHtml,\n  'date_generation': new Date().toLocaleDateString('fr-FR')\n};\n\nfor (const [key, value] of Object.entries(replacements)) {\n  html = html.replace(new RegExp(`\\\\{\\\\{${key}\\\\}\\\\}`, 'g'), value);\n}\n\nreturn [{\n  json: {\n    html_emargement: html,\n    nom_fichier: `Emargement_${session.session_id}.pdf`,\n    session_id: session.session_id\n  }\n}];"
      },
      "id": "prepare-emargement-pdf",
      "name": "Préparer Émargement PDF",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 300],
      "notes": "Lit le fichier template templates/template_emargement.html depuis le filesystem n8n. Construit dynamiquement les lignes {{rows_emargement}} avec les données de présence. N'embarque PAS le template."
    },
