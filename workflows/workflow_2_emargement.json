      "id": "loop-inscrits",
      "name": "Boucle Inscrits",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1440, 300],
      "notes": "Itère sur chaque inscrit de la session. Traite un inscrit à la fois : construction URL émargement, envoi email, log. Reboucle jusqu'à épuisement."
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// Construire l'URL pré-remplie du Google Form Émargement\n// ============================================================\n\nconst inscrit = $json;\nconst session = $('Filtrer').item.json;\nconst formation = $('Lire Formation').item.json;\n\nconst formId = '1juZyWTwTTHYSNsq8fChTopbs0XPbtHHC1rNrq_jfnUQ';\nconst dateJour = new Date().toLocaleDateString('fr-FR');\n\nconst baseUrl = `https://docs.google.com/forms/d/e/${formId}/viewform`;\nconst params = new URLSearchParams({\n  'entry.inscription_id': inscrit.inscription_id || '',\n  'entry.session_id': session.session_id || '',\n  'entry.apprenant_nom': inscrit.nom || '',\n  'entry.apprenant_prenom': inscrit.prenom || '',\n  'entry.date_jour': dateJour\n});\n\nconst url = `${baseUrl}?${params.toString()}`;\n\nreturn [{\n  json: {\n    ...inscrit,\n    url_emargement: url,\n    session_id: session.session_id,\n    formation_intitule: formation.intitule || '',\n    date_debut: session.date_debut || '',\n    date_fin: session.date_fin || '',\n    date_jour: dateJour\n  }\n}];"
      },
      "id": "build-url-emargement",
      "name": "Construire URL Émargement",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 300],
      "notes": "Construit l'URL pré-remplie du Google Form d'émargement avec inscription_id, session_id, nom, prénom et date du jour en query params."
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Émargement — {{ $json.formation_intitule }} — {{ $json.date_jour }}",
        "emailType": "html",
        "message": "=<h2 style=\"color:#1a365d;\">Feuille d'émargement</h2><p>Bonjour {{ $json.prenom }},</p><p>Merci de confirmer votre présence à la formation <strong>{{ $json.formation_intitule }}</strong> en complétant l'émargement du jour.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:24px auto;\"><tr><td style=\"background-color:#1a365d;border-radius:6px;\"><a href=\"{{ $json.url_emargement }}\" target=\"_blank\" style=\"display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:15px;font-weight:bold;\">Émarger maintenant</a></td></tr></table><p style=\"font-size:13px;color:#666;\">Si le bouton ne fonctionne pas, copiez ce lien :<br/><a href=\"{{ $json.url_emargement }}\">{{ $json.url_emargement }}</a></p><p>Cordialement,<br/>L'équipe pédagogique</p><p style=\"font-size:12px;color:#999;\">Email généré automatiquement — Système Qualiopi</p>",
        "options": {}
      },
