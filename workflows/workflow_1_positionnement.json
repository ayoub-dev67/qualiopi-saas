            {
              "lookupColumn": "formation_id",
              "lookupValue": "={{ $('Filtrer').item.json.formation_id }}"
            }
          ]
        },
        "options": {}
      },
      "id": "read-formation",
      "name": "Lire Formation",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1200, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets OAuth2"
        }
      },
      "notes": "Lookup de la formation associée à la session via formation_id dans l'onglet Formations du classeur 01_Referentiel."
    },
    {
      "parameters": {
        "options": {
          "reset": false
        }
      },
      "id": "loop-inscrits",
      "name": "Boucle Inscrits",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1440, 300],
      "notes": "Itère sur chaque inscrit de la session. Traite un inscrit à la fois : construction URL, envoi email, log. Reboucle jusqu'à épuisement de la liste."
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// Construire l'URL pré-remplie du Google Form Positionnement\n// ============================================================\n// Le Google Form est pré-configuré avec des champs cachés\n// pour inscription_id et session_id, passés en query params.\n// ============================================================\n\nconst inscrit = $json;\nconst session = $('Filtrer').item.json;\nconst formation = $('Lire Formation').item.json;\n\nconst formId = '1Tkf-lm7Kd_6EaN7-MXja1zAhAKxqH-j1gOVONl7fUDA';\n\n// Construire l'URL pré-remplie\n// Les entry IDs doivent correspondre aux champs du Google Form\nconst baseUrl = `https://docs.google.com/forms/d/e/${formId}/viewform`;\nconst params = new URLSearchParams({\n  'entry.inscription_id': inscrit.inscription_id || '',\n  'entry.session_id': session.session_id || '',\n  'entry.apprenant_nom': inscrit.nom || '',\n  'entry.apprenant_prenom': inscrit.prenom || ''\n});\n\nconst url = `${baseUrl}?${params.toString()}`;\n\nreturn [{\n  json: {\n    ...inscrit,\n    url_positionnement: url,\n    session_id: session.session_id,\n    formation_intitule: formation.intitule || '',\n    date_debut: session.date_debut || '',\n    date_fin: session.date_fin || ''\n  }\n}];"
      },
      "id": "build-url-positionnement",
      "name": "Construire URL Positionnement",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 300],
      "notes": "Construit l'URL pré-remplie du Google Form de positionnement avec inscription_id, session_id, nom et prénom en query params."
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Questionnaire de positionnement — {{ $json.formation_intitule }}",
        "emailType": "html",
        "message": "=<h2 style=\"color:#1a365d;\">Questionnaire de positionnement</h2><p>Bonjour {{ $json.prenom }},</p><p>Dans le cadre de votre inscription à la formation <strong>{{ $json.formation_intitule }}</strong> (du {{ $json.date_debut }} au {{ $json.date_fin }}), nous vous invitons à compléter le questionnaire de positionnement ci-dessous.</p><p>Ce questionnaire nous permet d'évaluer votre niveau initial et d'adapter le contenu pédagogique à vos besoins.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:24px auto;\"><tr><td style=\"background-color:#1a365d;border-radius:6px;\"><a href=\"{{ $json.url_positionnement }}\" target=\"_blank\" style=\"display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:15px;font-weight:bold;\">Compléter le questionnaire</a></td></tr></table><p style=\"font-size:13px;color:#666;\">Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :<br/><a href=\"{{ $json.url_positionnement }}\">{{ $json.url_positionnement }}</a></p><p>Merci de le compléter avant le <strong>{{ $json.date_debut }}</strong>.</p><p>Cordialement,<br/>L'équipe pédagogique</p><p style=\"font-size:12px;color:#999;\">Email généré automatiquement — Système Qualiopi</p>",
        "options": {}
      },
      "id": "send-positionnement",
      "name": "Envoyer lien positionnement",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1920, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "GMAIL_CREDENTIAL_ID",
          "name": "Gmail OAuth2"
        }
      },
      "notes": "Envoie un email à l'inscrit avec le lien vers le Google Form de positionnement pré-rempli. Bouton CTA + lien texte de secours."
    },
