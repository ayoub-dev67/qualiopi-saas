          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "statut",
              "lookupValue": "planifiee"
            },
            {
              "lookupColumn": "workflow_1_ok",
              "lookupValue": "FALSE"
            },
            {
              "lookupColumn": "workflow_0_ok",
              "lookupValue": "TRUE"
            }
          ]
        },
        "options": {}
      },
      "id": "read-sessions",
