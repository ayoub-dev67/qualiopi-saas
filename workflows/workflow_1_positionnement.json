      "typeVersion": 2,
      "position": [720, 300],
      "notes": "Vérifie que des résultats non vides ont été retournés. Seules les sessions avec un session_id valide passent."
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "1sgr7DNrlQbV23HACKPWhhqlc2cRU17Y-Z5zGVmqL7JE",
